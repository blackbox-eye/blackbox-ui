  "cssStack": {
    "marketing": {
      "loadOrder": [
        "tailwind.full.css",
        "tokens.css",
        "custom-ui.css",
        "theme-overrides.css",
        "components/motion-safe.css",
        "components/hero-mobile.css",
        "components/mobile-nav-scale.css",
        "marketing.min.css"
      ],
      "conditionalMedia": {
        "hero-mobile.css": "(max-width: 768px)"
      }
    },
    "admin": {
      "loadOrder": [
        "admin.min.css"
      ],
      "conditionalLoad": {
        "qa-mode.css": "QA mode enabled"
      }
    }
  },
  "breakpoints": {
    "xs": "480px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "i18n": {
    "supportedLanguages": ["da", "en"],
    "default": "en",
    "detectionPriority": ["query", "cookie", "browser", "default"],
    "translationFiles": ["lang/da.json", "lang/en.json"]
  },
  "qaGates": {
    "G0": {
      "name": "Build Gate",
      "checks": ["css_build", "no_lint_errors"]
    },
    "G1": {
      "name": "Accessibility Gate",
      "checks": ["axe_core", "keyboard_nav", "focus_visible", "color_contrast", "touch_targets"]
    },
    "G2": {
      "name": "Visual Regression Gate",
      "checks": ["light_mode", "dark_mode", "mobile_375", "desktop_1280"]
    },
    "G3": {
      "name": "Functional Gate",
      "checks": ["contact_form", "language_switch", "theme_toggle", "mobile_menu"]
    },
    "G4": {
      "name": "Performance Gate",
      "checks": ["lcp_under_2.5s", "cls_under_0.1", "css_size_under_100kb"]
    },
    "G5": {
      "name": "Security Gate",
      "checks": ["csp_headers", "no_inline_js", "recaptcha_v3", "xss_prevention"]
    }
  },
  "testSuites": {
    "a11y": ["tests/a11y-hardgate.spec.js"],
    "visual": ["tests/light-dark-audit.spec.js", "tests/visual.spec.js"],
    "mobile": ["tests/mobile-ux-sprint4.spec.js", "tests/mobile-ux-sprint5.spec.js"],
    "functional": ["tests/qa-final.spec.js", "tests/ccs-login.spec.js"],
    "admin": ["tests/admin-features.spec.js", "tests/dashboard-accessibility.spec.js"]
  }
}
