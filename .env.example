# Blackbox EYE – Environment Configuration Example
# Copy the variables you need into your server environment (.htaccess, cPanel MultiPHP INI Editor, or Apache config)

# ── Site configuration ───────────────────────────────────────────────────────
# SetEnv SITE_BASE_URL "https://blackbox.codes"

# ── reCAPTCHA Standard v3 configuration (required for contact form) ──────────
SetEnv RECAPTCHA_SITE_KEY "your_recaptcha_v3_site_key_here"
SetEnv RECAPTCHA_SECRET_KEY "your_recaptcha_v3_secret_key_here"
# Leave empty for Standard v3. Only set if you intentionally use Enterprise:
# SetEnv RECAPTCHA_PROJECT_ID "your_gcp_project_id_here"

# Optional toggles
SetEnv RECAPTCHA_DEBUG "false"
# SetEnv CONTACT_EMAIL "ops@blackbox.codes"

# ── SMTP configuration (recommended for reliable delivery) ──────────────────
# Uncomment and provide values when switching from PHP mail() to SMTP
# SetEnv SMTP_HOST "smtp.example.com"
# SetEnv SMTP_PORT "587"
# SetEnv SMTP_USERNAME "your_smtp_username"
# SetEnv SMTP_PASSWORD "your_app_specific_password"
# SetEnv SMTP_SECURE "tls"        # or "ssl" for port 465
# SetEnv SMTP_DEBUG "false"       # set to true for temporary troubleshooting
# SetEnv SMTP_FROM_EMAIL "noreply@blackbox.codes"
# SetEnv SMTP_FROM_NAME "Blackbox EYE"

# Security Notes:
# 1. NEVER commit live keys or passwords to git
# 2. Prefer cPanel MultiPHP INI Editor for secrets (keeps them off disk)
# 3. Rotate SMTP tokens regularly and revoke unused credentials
# 4. Disable RECAPTCHA_DEBUG and SMTP_DEBUG in production once testing is complete

# See RECAPTCHA-SETUP-GUIDE.md and SMTP-DEPLOYMENT-GUIDE.md for details
