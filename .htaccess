# reCAPTCHA environment variables
SetEnv RECAPTCHA_SITE_KEY "your_site_key_here"
SetEnv RECAPTCHA_SECRET_KEY "REPLACE_ME"
SetEnv RECAPTCHA_PROJECT_ID "your-project-id"
SetEnv RECAPTCHA_DEBUG "true"

# Prioriter PHP-indgangen og fald tilbage til HTML hvis nødvendigt.
DirectoryIndex index.php index.html

# Bevarer de eksisterende regler for "clean URLs".
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ index.php [L,QSA]
