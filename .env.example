# Blackbox EYE - Environment Configuration Example
# Copy this to .htaccess and replace with your actual values

# Site Configuration
# SetEnv SITE_BASE_URL "https://blackbox.codes"

# reCAPTCHA Enterprise Configuration
# Required for contact form to work
SetEnv RECAPTCHA_SITE_KEY "your_recaptcha_site_key_here"
SetEnv RECAPTCHA_SECRET_KEY "your_recaptcha_secret_key_here"
SetEnv RECAPTCHA_PROJECT_ID "your_gcp_project_id_here"

# Optional: Enable debug logging (true/false)
SetEnv RECAPTCHA_DEBUG "false"

# Optional: Override default contact email
# SetEnv CONTACT_EMAIL "ops@blackbox.codes"

# SMTP Configuration (optional - uses mail() if not set)
# SetEnv SMTP_HOST "smtp.example.com"
# SetEnv SMTP_PORT "587"
# SetEnv SMTP_USERNAME "your_smtp_username"
# SetEnv SMTP_PASSWORD "your_smtp_password"
# SetEnv SMTP_SECURE "tls"
# SetEnv SMTP_FROM_EMAIL "noreply@blackbox.codes"
# SetEnv SMTP_FROM_NAME "Blackbox EYE"

# Security Notes:
# 1. NEVER commit actual keys to git
# 2. Keep RECAPTCHA_SECRET_KEY confidential
# 3. Verify all keys are set before deploying
# 4. Use strong passwords for SMTP authentication

# See RECAPTCHA-SETUP-GUIDE.md for detailed configuration instructions
